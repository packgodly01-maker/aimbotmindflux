-- ────────────────────────────────────────────────
--                  Desync Logic
-- ────────────────────────────────────────────────

enableButton.MouseButton1Click:Connect(function()
    -- Quick visual feedback
    enableButton.BackgroundColor3 = Color3.fromRGB(14, 210, 144) -- success green
    
    task.delay(1, function()
        enableButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    end)

    -- Attempt to get current character
    local character = LocalPlayer.Character
    if not character then
        StarterGui:SetCore("SendNotification", {
            Title = "Silly desync",
            Text = "No character found. Try again when loaded.",
            Duration = 4
        })
        return
    end

    -- Kill humanoid → clear children → replace character with empty model
    local humanoid = character:FindFirstChildWhichIsA("Humanoid")
    if humanoid then
        humanoid:ChangeState(Enum.HumanoidStateType.Dead)
    end

    character:ClearAllChildren()

    -- Create dummy empty model and force-assign it
    local dummyModel = Instance.new("Model")
    dummyModel.Name = "DesyncDummy"
    dummyModel.Parent = Workspace

    LocalPlayer.Character = dummyModel
    task.wait()                    -- small wait helps sync the assignment

    -- Most aggressive desync step — setting to empty table
    LocalPlayer.Character = {}

    -- Clean up dummy
    dummyModel:Destroy()

    -- Notify user
    StarterGui:SetCore("SendNotification", {
        Title   = "mindflux desync",
        Text    = "Desync enabled — will persist until you close Roblox",
        Duration = 5
    })
end)
